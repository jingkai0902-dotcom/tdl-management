[Unit]
Description=TDL Management Backend
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/bots/tdl/backend
EnvironmentFile=/opt/bots/tdl/backend/.env
Environment=PYTHONPATH=/opt/bots/tdl/backend
ExecStart=/opt/bots/tdl/backend/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8010
Restart=always
RestartSec=3
User=root

[Install]
WantedBy=multi-user.target